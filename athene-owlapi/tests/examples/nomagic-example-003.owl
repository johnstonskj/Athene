Prefix( : = <http://nomagic.com/ontology/example-case/case-04> )
Ontology(<http://nomagic.com/ontology/example-case/case-04>
 		Declaration(
 				Class(:FutsalTeam)
		)
		Declaration(
				Class(:SoccerTeam)
		)
